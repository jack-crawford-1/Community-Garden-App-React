{
  "name": "growlocal-api",
  "version": "1.0.0",
  "description": "API for GrowLocal — a directory of community gardens in Aotearoa New Zealand",
  "license": "MIT",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently -n api,web \"nodemon server.js\" \"npm run dev --prefix ../client\"",
    "dev:api": "nodemon server.js",
    "seed": "node scripts/seed.js",
    "fetch:wcc": "node scripts/fetch-wcc-gardens.js --out data/gardens.json",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "mongoose": "^8.19.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.10"
  }
}
